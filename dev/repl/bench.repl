;; Muutos
(require '[muutos.sql-client :as sql])
(require '[criterium.bench :as bench])
(require '[clj-async-profiler.core :as profiler])

(def q-film-by-id
  "SELECT release_year,
          length,
          TRIM(language.name) AS language,
          title,
          rating,
          description,
          rental_rate,
          replacement_cost
   FROM film
   JOIN language ON language.language_id = film.language_id
   WHERE film.film_id = $1
   LIMIT 1")

(def pg (sql/connect :key-fn (fn [_ attr-name] (keyword attr-name))))

(bench/bench (sql/eq pg [q-film-by-id 42]) :limit-time-s 30)

(profiler/profile
  (dotimes [_ 10000]
    (sql/eq pg [q-film-by-id 42])))

;; JDBC
(require '[next.jdbc :as jdbc])

(def jdbc-conn
  (jdbc/get-connection {:dbtype "postgres"
                        :dbname "postgres"
                        :user "postgres"
                        :password "postgres"
                        :prepareThreshold 0}))

(defmacro ->jdbc [q]
  `(clojure.string/replace ~q #"(\$\d+)" "?"))

(def q (->jdbc q-film-by-id))

(bench/bench (jdbc/execute! jdbc-conn [(->jdbc q-film-by-id) 42]) :limit-time-s 30)

(profiler/serve-ui 8080)

(require '[clojure.java.browse :as browse])
(browse/browse-url "http://localhost:8080")
