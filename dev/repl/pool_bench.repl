(require '[clojure.repl.deps :as deps])

(deps/add-libs '{criterium/criterium {:mvn/version "0.5.153-ALPHA"}})

(deps/add-libs '{com.github.seancorfield/next.jdbc {:mvn/version "1.3.1093"}
                 org.postgresql/postgresql {:mvn/version "42.7.10"}
                 com.zaxxer/HikariCP {:mvn/version "7.0.2"}})

(require '[next.jdbc :as jdbc])
(require '[next.jdbc.connection :as connection])
(require '[muutos.test.concurrency :refer [concurrently]])
(require '[criterium.core :refer [quick-bench]])

(import '(com.zaxxer.hikari HikariDataSource))

(def q-film-by-id
  "SELECT release_year,
          length,
          TRIM(language.name) AS language,
          title,
          rating,
          description,
          rental_rate,
          replacement_cost
   FROM film
   JOIN language ON language.language_id = film.language_id
   WHERE film.film_id = $1
   LIMIT 1")

(defmacro ->jdbc [q]
  `(clojure.string/replace ~q #"(\$\d+)" "?"))

(comment (->jdbc q-film-by-id) ,,,)

(def jdbc-pool
  (connection/->pool HikariDataSource
    {:dbtype "postgres" :dbname "postgres" :username "postgres" :password "postgres"}))

(quick-bench
  (concurrently {:threads 1000}
    (assert (= [{:film/release_year 2008
                 :film/length 170
                 :language "German"
                 :film/title "ARTIST COLDBLOODED"
                 :film/rating "NC-17"
                 :film/description "A Stunning Reflection of a Robot And a Moose who must Challenge a Woman in California"
                 :film/rental_rate 2.99M
                 :film/replacement_cost 10.99M}]
              (jdbc/execute! jdbc-pool [(->jdbc q-film-by-id) 42])))))
;; Execution time mean : 22.269118 ms

(deps/add-libs '{com.github.igrishaev/pg2-core {:mvn/version "0.1.48"}})

(require '[pg.core :as pg])
(require '[pg.oid :as oid])

(def config
  {:host "127.0.0.1"
   :port 5432
   :user "postgres"
   :password "postgres"
   :database "postgres"
   :binary-encode? true
   :binary-decode? true
   :pool-max-size 10})

(def pg-conn (pg/connect config))

;; pg2 without connection pooling
(quick-bench
  (concurrently {:threads 1000}
    (assert (= [{:release_year 2008
                 :length 170
                 :language "German"
                 :title "ARTIST COLDBLOODED"
                 :rating "NC-17"
                 :description "A Stunning Reflection of a Robot And a Moose who must Challenge a Woman in California"
                 :rental_rate 2.99M
                 :replacement_cost 10.99M}]
              (pg/execute pg-conn q-film-by-id {:params [42] :oids [oid/int8]})))))
;; Execution time mean : 90.751762 ms

;; pg2 with connection pooling
(pg/with-pool [pg-pool config]
  (quick-bench
    (concurrently {:threads 1000}
      (pg/with-connection [conn pg-pool]
        (assert (= [{:release_year 2008
                     :length 170
                     :language "German"
                     :title "ARTIST COLDBLOODED"
                     :rating "NC-17"
                     :description "A Stunning Reflection of a Robot And a Moose who must Challenge a Woman in California"
                     :rental_rate 2.99M
                     :replacement_cost 10.99M}]
                  (pg/execute conn q-film-by-id {:params [42] :oids [oid/int8]})))))))
;; Execution time mean : 36.411568 ms

(require '[muutos.sql-client :as sql])

(def pg (sql/connect))
#_(.close pg)

(def ^:private q-insert-film
  "INSERT INTO film (title, description, release_year, language_id, rental_duration, rental_rate, length, replacement_cost, rating, special_features)
   VALUES ($1, $2, $3, $4, $5, $6, $7, $8, $9::mpaa_rating, $10)")

(def q-actor-by-title
  "SELECT actor.first_name, actor.last_name
   FROM film
   JOIN film_actor ON film_actor.film_id = film.film_id
   JOIN actor ON film_actor.actor_id = actor.actor_id WHERE title = $1")

(def q-delete-film-actor
  "DELETE FROM film_actor
   WHERE actor_id IN (SELECT actor_id FROM actor WHERE first_name = $1 AND last_name = $2)
   AND film_id IN (SELECT film_id FROM film  WHERE title = $3)")

(def q-delete-actor
  "DELETE FROM actor WHERE first_name = $1 AND last_name = $1")

(def q-delete-film
  "DELETE FROM film WHERE title = $1")

(def q-insert-actor
  "INSERT INTO actor (first_name, last_name) VALUES ($1, $2)")

(def q-insert-film-actor
  "INSERT INTO film_actor (actor_id, film_id) VALUES (currval('actor_actor_id_seq'), currval('film_film_id_seq'))")

(require '[hukari.jfr :as jfr])

(with-open [_ (jfr/start :configuration :profile)]
  (dotimes [_ 1000]
    (sql/eq pg
      [q-delete-film-actor "HUMPHREY" "DIESEL" "GALAXY TORRENT"]
      [q-delete-actor "HUMPHREY" "DIESEL"]
      [q-delete-film "GALAXY TORRENT"]
      [q-insert-film "GALAXY TORRENT"
       "A Epic Tale of a Fearless Astronaut And a Rogue Scientist Who Must Conquer a Supernova in The Outer Reaches of Space"
       2006 1 5 2.99M 112 21.99M "PG-13" (into-array String ["Trailers" "Behind the Scenes"])]
      [q-insert-actor "HUMPHREY" "DIESEL"]
      [q-insert-film-actor]
      [q-actor-by-title "GALAXY TORRENT"])))

(dotimes [_ 100]
  (jdbc/with-transaction [tx jdbc-pool]
    (jdbc/execute! tx [(->jdbc q-delete-film-actor) "HUMPHREY" "DIESEL" "GALAXY TORRENT"])
    (jdbc/execute! tx [(->jdbc q-delete-actor) "HUMPHREY" "DIESEL"])
    (jdbc/execute! tx [(->jdbc q-delete-film) "GALAXY TORRENT"])
    (jdbc/execute! tx [(->jdbc q-insert-film) "GALAXY TORRENT"
                       "A Epic Tale of a Fearless Astronaut And a Rogue Scientist Who Must Conquer a Supernova in The Outer Reaches of Space"
                       2006 1 5 2.99M 112 21.99M "PG-13" (into-array String ["Trailers" "Behind the Scenes"])])
    (jdbc/execute! tx [(->jdbc q-insert-actor) "HUMPHREY" "DIESEL"])
    (jdbc/execute! tx [(->jdbc q-insert-film-actor)])
    (jdbc/execute! tx [(->jdbc q-actor-by-title) "GALAXY TORRENT"])))